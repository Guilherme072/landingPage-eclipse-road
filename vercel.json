{
  "cleanUrls": true,
  "rewrites": [
    { "source": "/index", "destination": "/index.html" },
    { "source": "/agenciados", "destination": "/agenciados.html" },
    { "source": "/produtora", "destination": "/produtora.html" },
    { "source": "/sobre-nos", "destination": "/sobre-nos.html" },
    { "source": "/api/(.*)", "destination": "/api/send-email.js" }
  ],
  "builds": [
    {
      "src": "api/send-email.js",
      "use": "@vercel/node"
    }
  ]
}
